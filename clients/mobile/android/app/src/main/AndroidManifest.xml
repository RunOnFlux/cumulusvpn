<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- CumulusVPN WireGuard tunnel (VpnService). -->
    <uses-permission android:name="android.permission.BIND_VPN_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
      android:name=".MainApplication"
      android:label="@string/app_name"
      android:icon="@mipmap/ic_launcher"
      android:roundIcon="@mipmap/ic_launcher_round"
      android:allowBackup="false"
      android:theme="@style/AppTheme"
      android:networkSecurityConfig="@xml/network_security_config"
      android:supportsRtl="true">
      <activity
        android:name=".MainActivity"
        android:label="@string/app_name"
        android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
        android:launchMode="singleTask"
        android:windowSoftInputMode="adjustResize"
        android:exported="true">
        <intent-filter>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
      </activity>

      <!-- The wireguard-android backend (GoBackend) owns the actual tun device
           via its own bundled VpnService subclass; we must declare it here so
           the OS routes the VPN intent to it. BIND_VPN_SERVICE ensures only the
           system can bind it. CumulusTunnelController (CumulusVpnService.kt)
           drives this service through GoBackend.setState(...). -->
      <service
        android:name="com.wireguard.android.backend.GoBackend$VpnService"
        android:permission="android.permission.BIND_VPN_SERVICE"
        android:foregroundServiceType="specialUse"
        android:exported="false">
        <intent-filter>
          <action android:name="android.net.VpnService" />
        </intent-filter>
        <property
          android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
          android:value="CumulusVPN WireGuard tunnel" />
      </service>

      <!-- CumulusVPN multi-hop (nested) tunnel. Owns its own OS tun and runs the
           userspace wgnest core (two stacked wireguard-go devices) via the
           wgmobile AAR. Separate from GoBackend's service because true nesting
           needs the raw tun fd, which GoBackend does not expose. Consent is
           app-level, so the same VpnService.prepare() covers both. -->
      <service
        android:name=".tunnel.CumulusMultihopVpnService"
        android:permission="android.permission.BIND_VPN_SERVICE"
        android:foregroundServiceType="specialUse"
        android:exported="false">
        <intent-filter>
          <action android:name="android.net.VpnService" />
        </intent-filter>
        <property
          android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
          android:value="CumulusVPN multi-hop tunnel" />
      </service>

      <!-- Obfuscated (AmneziaWG) single-hop tunnel, Stealth mode. Runs in the
           userspace wgnest core (same as multi-hop) rather than GoBackend, so it
           needs its own VpnService declaration. -->
      <service
        android:name=".tunnel.CumulusObfsVpnService"
        android:permission="android.permission.BIND_VPN_SERVICE"
        android:foregroundServiceType="specialUse"
        android:exported="false">
        <intent-filter>
          <action android:name="android.net.VpnService" />
        </intent-filter>
        <property
          android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
          android:value="CumulusVPN obfuscated tunnel" />
      </service>
    </application>
</manifest>
