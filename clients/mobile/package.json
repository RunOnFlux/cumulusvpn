{
  "name": "@cumulusvpn/mobile",
  "version": "0.1.0",
  "private": true,
  "description": "CumulusVPN mobile client — React Native (iOS + Android). Connect-only store-compliant build; shares @cumulusvpn/core for discovery, enrollment, status and payment-code logic.",
  "license": "MIT",
  "scripts": {
    "start": "react-native start",
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest"
  },
  "dependencies": {
    "@cumulusvpn/core": "file:../core-ts",
    "react": "19.2.7",
    "react-native": "0.86.0",
    "react-native-get-random-values": "1.11.0",
    "react-native-safe-area-context": "5.8.0",
    "text-encoding-polyfill": "0.6.7"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/runtime": "7.29.7",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.86.0",
    "@react-native/jest-preset": "0.86.0",
    "@react-native/metro-config": "0.86.0",
    "@types/jest": "29.5.14",
    "@types/react": "19.2.17",
    "@types/react-test-renderer": "19.1.0",
    "eslint": "10.7.0",
    "jest": "29.7.0",
    "prettier": "3.9.5",
    "react-test-renderer": "19.2.7",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0"
  }
}
