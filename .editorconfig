# EditorConfig — https://editorconfig.org
# Top-level config for the CumulusVPN monorepo.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Go uses tabs (gofmt is authoritative).
[*.go]
indent_style = tab
indent_size = 4

[go.mod]
indent_style = tab

[Makefile]
indent_style = tab

# Markdown: keep trailing whitespace (hard line breaks).
[*.md]
trim_trailing_whitespace = false

[*.{yml,yaml}]
indent_size = 2
